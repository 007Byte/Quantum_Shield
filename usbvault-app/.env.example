# API Configuration
EXPO_PUBLIC_API_URL=https://api.usbvault.io

# USB Companion Service (local — runs on user's machine for USB hardware access)
EXPO_PUBLIC_USB_COMPANION_URL=http://localhost:3001

# Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_DATA=false
EXPO_PUBLIC_DEBUG_MODE=false

# Sentry Error Tracking
# Get your DSN from https://sentry.io → Settings → Projects → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog Analytics (optional — events buffer locally until configured)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# RevenueCat In-App Purchases (optional — free tier mode when not set)
EXPO_PUBLIC_REVENUECAT_KEY=
