{
  "expo": {
    "name": "Quantum_Shield",
    "slug": "usbvault",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0B1E"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/usbvault",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.usbvault.enterprise",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:api.usbvault.io",
        "webcredentials:api.usbvault.io"
      ],
      "infoPlist": {
        "NSFaceIDUsageDescription": "We use Face ID to securely authenticate you.",
        "NSLocalNetworkUsageDescription": "We need access to scan your local network for USB devices.",
        "NSBonjourServiceTypes": ["_http._tcp"],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          },
          "_F8_PINNING_README": "F8 iOS TLS pinning scaffold. To enable: (1) fill real SPKI SHA-256 base64 pins per usbvault-app/PINNING.md, (2) rename the disabled key below to 'NSPinnedDomains', (3) replace the AAAA/BBBB placeholders with primary+backup pins, (4) run expo prebuild and device-test. Pinning is FAIL-CLOSED, so do NOT enable with placeholders.",
          "_F8_NSPinnedDomains_DISABLED": {
            "api.usbvault.io": {
              "NSIncludesSubdomains": true,
              "NSPinnedLeafIdentities": [
                { "SPKI-SHA256-BASE64": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" },
                { "SPKI-SHA256-BASE64": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=" }
              ]
            }
          }
        }
      }
    },
    "android": {
      "package": "com.usbvault.enterprise",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.usbvault.io",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "api.usbvault.io",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0B1E"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_PHONE_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "networkSecurityConfig": "./native/android/app/src/main/res/xml/network_security_config.xml",
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "usbvault",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      ["@sentry/react-native/expo", {
        "organization": "usbvault",
        "project": "usbvault-mobile"
      }],
      "expo-updates",
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#7C3AED"
      }]
    ]
  }
}
