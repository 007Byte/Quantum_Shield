# Certificate Pinning Configuration (Required for Production)
# PH1-FIX: Production-ready certificate pinning configuration
#
# Generate pins using the following command:
#   openssl s_client -connect api.usbvault.io:443 -servername api.usbvault.io < /dev/null 2>/dev/null \
#     | openssl x509 -pubkey -noout \
#     | openssl pkey -pubin -outform der \
#     | openssl dgst -sha256 -binary \
#     | openssl enc -base64
#
# Or use the extraction script: scripts/extract-pins.sh <hostname>
#
# Pin strategy:
# - Primary pin: current leaf certificate SPKI hash
# - Backup pin: intermediate CA SPKI hash (survives leaf rotation)
# - Pins are injected at build time via EXPO_PUBLIC_PIN_* environment variables

# Primary pin (leaf certificate SPKI SHA-256 hash, Base64-encoded)
# Replace with the actual pin from your primary certificate
EXPO_PUBLIC_PIN_PRIMARY=REPLACE_WITH_PRIMARY_PIN_SHA256_BASE64

# Backup pin (intermediate CA SPKI SHA-256 hash, Base64-encoded)
# Replace with the actual pin from your backup/intermediate certificate
EXPO_PUBLIC_PIN_BACKUP=REPLACE_WITH_BACKUP_PIN_SHA256_BASE64

# Pin expiration date (ISO 8601 format)
# Pins should be rotated before this date to avoid service interruption
EXPO_PUBLIC_PIN_EXPIRATION=2027-03-09T00:00:00Z

# API hostname for certificate pinning
# Must match the domain where API requests are made
EXPO_PUBLIC_API_URL=https://api.usbvault.io

# API hostname (used by certificate pinning module)
# Note: EXPO_PUBLIC_API_HOSTNAME is read by certificatePinning.ts
# If not set, defaults to 'api.usbvault.io'
# EXPO_PUBLIC_API_HOSTNAME=api.usbvault.io

# Sentry Error Tracking (Required for Production)
# Get DSN from https://sentry.io → Settings → Projects → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
