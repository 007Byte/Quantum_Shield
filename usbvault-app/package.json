{
  "name": "usbvault-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "test": "node --stack-size=8192 ./node_modules/.bin/jest",
    "test:components": "jest --config jest.config.components.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "bash scripts/capture-screenshots.sh",
    "test:maestro": "maestro test maestro/flows/",
    "test:maestro:single": "maestro test",
    "validate-env": "bash scripts/validate-env.sh",
    "validate-env:prod": "bash scripts/validate-env.sh --production",
    "prebuild:production": "bash scripts/validate-env.sh --production",
    "export:web": "expo export --platform web",
    "export:usb": "EXPO_PUBLIC_API_URL= EXPO_PUBLIC_USB_STANDALONE=true expo export --platform web --output-dir ../usb-companion/static"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
