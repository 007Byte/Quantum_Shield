# Database
DATABASE_URL=postgres://usbvault:password@localhost:5432/usbvault?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# S3 / Object Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=usbvault-production
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
AWS_REGION=us-east-1

# JWT Configuration
JWT_ED25519_PRIVATE_KEY=base64_encoded_ed25519_private_key
JWT_ED25519_PUBLIC_KEY=base64_encoded_ed25519_public_key

# Stripe Billing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (from Stripe Dashboard > Products)
STRIPE_PRICE_INDIVIDUAL=price_individual_placeholder
STRIPE_PRICE_TEAM=price_team_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# FIDO2/WebAuthn
FIDO2_RELYING_PARTY_ID=usbvault.io
FIDO2_RELYING_PARTY_NAME=USBVault
FIDO2_RELYING_PARTY_ORIGIN=https://usbvault.io

# Server
SERVER_PORT=8080
LOG_LEVEL=info

# Optional: APNs push notifications (iOS)
APNS_KEY_ID=your_key_id
APNS_TEAM_ID=your_team_id
APNS_BUNDLE_ID=io.usbvault.app
APNS_PRIVATE_KEY_PATH=/path/to/apns/key.p8

# Optional: Firebase Cloud Messaging (Android)
FCM_PROJECT_ID=your_project_id
FCM_SERVICE_ACCOUNT_JSON=/path/to/firebase/service-account.json
