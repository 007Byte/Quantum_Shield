# Environment files - NEVER commit these to version control
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.test.local
.env.production.local

# Build artifacts
bin/
dist/
*.o
*.so
*.dylib
*.dll
*.exe
.bin

# Security scanning reports
/tmp/
*.json.bak
/coverage/
.scannerwork/
# Generated security-audit artifacts (preflight consolidated audit) — regenerable
# build output, not source. Keep them out of git so they can't be swept into a
# `git stash -u` and later trip the gitleaks gate (the test-fixture leaks fix).
docs/security/AUDIT_REPORT.html
docs/security/reports/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.vim
.emacs.d

# Go-specific
go.sum.backup
vendor/
*.test

# Rust-specific
target/
Cargo.lock.backup
.cargo/

# Docker volumes (not committed but useful to gitignore)
postgres-data/
redis-data/
minio-data/

# Temporary files
*.tmp
*.temp
*.log
logs/

# Dependency files (for some projects)
node_modules/
yarn.lock

# Application state
*.db
*.sqlite
*.sqlite3

# OS files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Network files
*.pcap
*.pcapng

# Secrets and credentials
secrets/
credentials/
*.key
*.pem
*.cert
*.crt
!.env.example

# USB-COMP-1: Vendored Node.js binaries (downloaded at build time)
usb-companion/node/

# REPO-1: Pre-built static assets (built from source in CI)
usb-companion/static/

# Terraform providers (too large for GitHub)
.terraform/
deploy/terraform/.terraform/

# npm cache
.npm-cache/

# Archive / dead code
archive/

# Generated analysis artifacts
codebase_*.png
codebase_*.html

# Claude Code config (local only)
.claude/

# Misc logs and temp files
*.log
.npm-install-log.txt

# Build output
.next/
out/
playwright-report/
test-results/

# Enterprise docs (generated from .md sources)
docs/enterprise/*.docx

# Claude AI config
CLAUDE.md
**/CLAUDE.md

# Captured Go test output (build artifact — contains ephemeral keys/token-shaped strings, not real secrets)
usbvault-server/test_results.txt
test_results.txt
