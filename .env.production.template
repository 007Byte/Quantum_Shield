# ===========================================================================
# Quantum_Shield — Production Environment Configuration
# ===========================================================================
#
# Copy this file to .env and replace all <REPLACE_WITH_VALUE> placeholders.
# Generate secrets with: ./scripts/generate-secrets.sh ./secrets
# Validate with:         ./scripts/validate-env.sh .env
#
# IMPORTANT: Never commit the populated .env file to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Format: postgres://user:password@host:port/database?sslmode=MODE
# SSL modes for production: verify-ca or verify-full (REQUIRED)
# Generate password with: openssl rand -base64 32 | tr -d '/+=' | head -c 40
DATABASE_URL=postgres://usbvault:<REPLACE_WITH_PASSWORD>@<REPLACE_WITH_HOST>:5432/usbvault?sslmode=verify-full

# Connection pool tuning (optional — sensible defaults are used if unset)
DB_MAX_CONNECTIONS=30
DB_MIN_CONNECTIONS=5

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Format: redis://:password@host:port
# For TLS: rediss://:password@host:6379
# Generate password with: openssl rand -base64 32 | tr -d '/+=' | head -c 40
REDIS_URL=redis://:<REPLACE_WITH_PASSWORD>@<REPLACE_WITH_HOST>:6379

# Optional: Redis Sentinel for high availability
# Comma-separated list of sentinel addresses
# REDIS_SENTINEL_ADDRS=sentinel1:26379,sentinel2:26379,sentinel3:26379
# REDIS_SENTINEL_MASTER=mymaster

# ---------------------------------------------------------------------------
# S3 / Object Storage (encrypted blobs)
# ---------------------------------------------------------------------------
# For AWS S3:        https://s3.amazonaws.com
# For MinIO:         https://minio.your-domain.com
# For DigitalOcean:  https://<region>.digitaloceanspaces.com
S3_ENDPOINT=<REPLACE_WITH_ENDPOINT>
AWS_ENDPOINT=<REPLACE_WITH_ENDPOINT>
S3_BUCKET=<REPLACE_WITH_BUCKET_NAME>
AWS_REGION=us-east-1

# S3 credentials
AWS_ACCESS_KEY_ID=<REPLACE_WITH_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<REPLACE_WITH_SECRET_KEY>

# ---------------------------------------------------------------------------
# Authentication — JWT ED25519 Keys
# ---------------------------------------------------------------------------
# OPTION A (RECOMMENDED): File-based keys
# Point to files generated by: ./scripts/generate-secrets.sh
JWT_ED25519_PRIVATE_KEY_FILE=/etc/usbvault/secrets/jwt_private.key
JWT_ED25519_PUBLIC_KEY_FILE=/etc/usbvault/secrets/jwt_public.key

# OPTION B: Inline base64-encoded keys (less secure — secrets visible in env)
# Generate with: ./scripts/generate-secrets.sh
# JWT_ED25519_PRIVATE_KEY=<REPLACE_WITH_BASE64_PRIVATE_KEY>
# JWT_ED25519_PUBLIC_KEY=<REPLACE_WITH_BASE64_PUBLIC_KEY>

# ---------------------------------------------------------------------------
# Backup Encryption
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=<REPLACE_WITH_BASE64_KEY>
BACKUP_STORAGE_PATH=/var/backups/usbvault
BACKUP_S3_BUCKET=usbvault-backups
BACKUP_S3_REGION=us-east-1
BACKUP_SCHEDULE=0 2 * * *

# ---------------------------------------------------------------------------
# Stripe Billing
# ---------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use sk_live_ keys for production (not sk_test_)
STRIPE_SECRET_KEY=<REPLACE_WITH_STRIPE_LIVE_SECRET_KEY>

# Webhook signing secret from: Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=<REPLACE_WITH_WHSEC_VALUE>

# Price IDs from: Stripe Dashboard > Products
STRIPE_PRICE_INDIVIDUAL=<REPLACE_WITH_PRICE_ID>
STRIPE_PRICE_TEAM=<REPLACE_WITH_PRICE_ID>
STRIPE_PRICE_ENTERPRISE=<REPLACE_WITH_PRICE_ID>

# ---------------------------------------------------------------------------
# FIDO2/WebAuthn
# ---------------------------------------------------------------------------
FIDO2_RELYING_PARTY_ID=usbvault.io
FIDO2_RELYING_PARTY_NAME=Quantum_Shield
FIDO2_RELYING_PARTY_ORIGIN=https://usbvault.io

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
SERVER_PORT=8080
LOG_LEVEL=info

# Migrations directory (set if running from non-standard location)
# MIGRATIONS_DIR=/app/migrations

# ---------------------------------------------------------------------------
# Mobile App — Certificate Pinning (optional but recommended)
# ---------------------------------------------------------------------------
# Generate pins with:
#   openssl s_client -connect api.usbvault.io:443 -servername api.usbvault.io < /dev/null 2>/dev/null \
#     | openssl x509 -pubkey -noout \
#     | openssl pkey -pubin -outform der \
#     | openssl dgst -sha256 -binary \
#     | openssl enc -base64
EXPO_PUBLIC_PIN_PRIMARY=
EXPO_PUBLIC_PIN_BACKUP=
EXPO_PUBLIC_PIN_EXPIRATION=2027-03-09T00:00:00Z
EXPO_PUBLIC_API_URL=https://api.usbvault.io

# ---------------------------------------------------------------------------
# Monitoring (optional but recommended)
# ---------------------------------------------------------------------------
# Sentry DSN from: https://sentry.io > Settings > Projects > Client Keys
EXPO_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Push Notifications (optional)
# ---------------------------------------------------------------------------
# Apple Push Notification Service (iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=io.usbvault.app
APNS_PRIVATE_KEY_PATH=

# Firebase Cloud Messaging (Android)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
