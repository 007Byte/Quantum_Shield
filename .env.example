# PostgreSQL Configuration
# Connection string format: postgres://username:password@host:port/database?sslmode=disable
# For production, use sslmode=require
DATABASE_URL=postgres://usbvault:your_secure_password@localhost:5432/usbvault_dev?sslmode=disable

# Redis Configuration
# Format: redis://:password@host:port
# For production, always use strong passwords and consider using Redis with TLS
REDIS_URL=redis://:your_secure_redis_password@localhost:6379

# MinIO/S3-Compatible Storage Configuration
# AWS_ENDPOINT: The MinIO server endpoint URL
AWS_ENDPOINT=http://localhost:9000

# AWS_ACCESS_KEY_ID: MinIO root username (change from default minioadmin)
AWS_ACCESS_KEY_ID=minioadmin

# AWS_SECRET_ACCESS_KEY: MinIO root password (change from default)
AWS_SECRET_ACCESS_KEY=minioadmin_secret

# AWS_REGION: Default region for S3 operations
AWS_REGION=us-east-1

# S3_BUCKET: Name of the bucket for encrypted blobs
S3_BUCKET=usbvault-encrypted-blobs

# API Server Configuration
# SERVER_PORT: Port on which the API server listens
SERVER_PORT=8080

# LOG_LEVEL: Logging level (debug, info, warn, error)
LOG_LEVEL=info

# FIDO2/WebAuthn Configuration
# These values define how the server identifies itself to WebAuthn clients
# FIDO2_RELYING_PARTY_ID: The domain/origin for FIDO2 authentication
FIDO2_RELYING_PARTY_ID=localhost

# FIDO2_RELYING_PARTY_NAME: Display name for the WebAuthn relying party
FIDO2_RELYING_PARTY_NAME=USBVault Dev

# FIDO2_RELYING_PARTY_ORIGIN: The full origin URL for WebAuthn
FIDO2_RELYING_PARTY_ORIGIN=http://localhost:8080

# JWT Configuration
# ED25519 private key for JWT signing (leave empty to auto-generate in development)
# Format: base64-encoded or PEM format
# DO NOT commit the actual key to version control
JWT_ED25519_PRIVATE_KEY=

# ED25519 public key for JWT verification (leave empty to auto-generate in development)
JWT_ED25519_PUBLIC_KEY=

# Application Environment
# Values: development, staging, production
ENVIRONMENT=development
